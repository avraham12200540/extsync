{
  "manifest_version": 3,
  "name": "Hello ExtSync",
  "version": "1.0.0",
  "description": "תוסף דוגמה להדגמת מחזור החיים המלא של ExtSync (התקנה, עדכון, reload).",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hello ExtSync"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  },
  "permissions": ["storage", "nativeMessaging"]
}
