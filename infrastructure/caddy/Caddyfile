# Caddy reverse proxy with automatic HTTPS (Let's Encrypt).
# DOMAIN is provided via the environment (see docker-compose.prod.yml).
# Point these DNS A-records at the VPS:  api.<domain>  and  files.<domain>.
# (The website itself is served by Vercel at <domain>/www — not here.)

# Shared hardening headers for every response Caddy serves.
(security_headers) {
	header {
		# Force HTTPS for two years, including subdomains.
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		# Don't let browsers MIME-sniff responses into a different content type.
		X-Content-Type-Options "nosniff"
		# These hosts are never meant to be framed.
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Don't advertise the server software.
		-Server
	}
}

# API
api.{$DOMAIN} {
	import security_headers
	# Reject oversized bodies at the edge before the app buffers them into memory
	# (the upload cap is 50MB; this leaves headroom for multipart overhead).
	request_body {
		max_size 60MB
	}
	encode gzip zstd
	reverse_proxy api:8000
}

# Public artifact downloads (MinIO, artifacts bucket is anonymous-download).
# Used both by the Agent and by the "manual download" button in the store.
files.{$DOMAIN} {
	import security_headers
	encode gzip
	# Force the browser to SAVE artifact ZIPs ("Download ZIP" button) rather than
	# navigate to / preview them. The <a download> hint in the web app is ignored
	# because the file is cross-origin (files. vs the site), so the attachment
	# disposition must come from the server. Matches *.zip only (the artifacts);
	# icons/screenshots are images and are untouched, and the Agent downloads
	# programmatically so this header is a no-op for it.
	@zip path *.zip
	header @zip Content-Disposition attachment
	reverse_proxy minio:9000
}
