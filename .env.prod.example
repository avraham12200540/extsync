# =============================================================================
# ExtSync PRODUCTION env (VPS). Copy to .env.prod on the server and fill in.
#   cp .env.prod.example .env.prod   &&   nano .env.prod
# Generate secrets:  openssl rand -hex 32
# NEVER commit .env.prod (it is gitignored).
# =============================================================================

# ---- Your domain (registrable domain you bought) ----
DOMAIN=example.com
# Where the website (Vercel) lives — apex or www. Used for CORS + links + cookies.
WEB_DOMAIN=example.com

# ---- Postgres (runs in compose; back it up!) ----
POSTGRES_USER=extsync
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=extsync

# ---- Object storage (MinIO in compose; swap for Cloudflare R2 to scale) ----
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME_minio_access
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET_UPLOADS=extsync-uploads
S3_BUCKET_ARTIFACTS=extsync-artifacts

# ---- Secrets (openssl rand -hex 32) ----
JWT_SECRET=CHANGE_ME_hex32
CSRF_SECRET=CHANGE_ME_hex32
SIGNING_INTERNAL_TOKEN=CHANGE_ME_internal_only

# ---- Signing keys ----
# Generate on the server: python infrastructure/scripts/gen_signing_key.py
# but write to infrastructure/docker/prod-signing-key.pem, then paste the public
# key line it prints below. The Agent ships this same public key.
SIGNING_ACTIVE_KEY_ID=key-2026-01
SIGNING_PUBLIC_KEYS=key-2026-01:PASTE_BASE64_PUBLIC_KEY

# ---- Email ----
# PREFERRED: Resend HTTPS API (port 443) — works even when the VPS blocks outbound
# SMTP ports (most providers, incl. DigitalOcean, block 25/465/587). Just set this:
RESEND_API_KEY=CHANGE_ME_resend_api_key
EMAIL_FROM="ExtSync <no-reply@extsync.com>"     # must be on your verified domain
# Fallback SMTP (only used if RESEND_API_KEY is empty, and only if the port is open):
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=CHANGE_ME_resend_api_key
SMTP_USE_TLS=true
# Require a verified email before publishing. Turn on AFTER email delivery works
# and you've verified your own account (otherwise you lock yourself out).
ENFORCE_EMAIL_VERIFICATION=false

# ---- Tokens / limits (defaults are fine) ----
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
LOG_LEVEL=info
