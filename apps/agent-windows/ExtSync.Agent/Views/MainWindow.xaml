<Window x:Class="ExtSync.Agent.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ExtSync Agent" Height="640" Width="860"
        FlowDirection="RightToLeft" FontFamily="Segoe UI" WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceMuted}">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Surface}" Padding="20,16"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ExtSync Agent" FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                 Fill="{Binding ConnectionStatus, Converter={x:Null}}"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Margin="8,0" FontSize="13"
                                   Foreground="{StaticResource TextMuted}"/>
                        <TextBlock Text="{Binding LastCheckText}" Margin="16,0" FontSize="13"
                                   Foreground="{StaticResource TextMuted}"/>
                        <TextBlock Text="{Binding ManagedCountText}" Margin="16,0" FontSize="13"
                                   Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="הוספת תוסף מקישור" Command="{Binding AddByLinkCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="בדיקת עדכונים" Command="{Binding CheckUpdatesCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="הגדרות" Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Background="{StaticResource TextMuted}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Extension list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl ItemsSource="{Binding Extensions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Surface}" CornerRadius="12" Margin="0,0,0,12"
                                Padding="18" BorderBrush="{StaticResource Border}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding DeveloperName}" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="•" Margin="6,0" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding Version}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="•" Margin="6,0" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding Channel}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="•" Margin="6,0" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="{Binding BridgeText}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding StatusColor}"/>
                                        <TextBlock Text="{Binding StatusText}" Margin="8,0" FontSize="13"
                                                   Foreground="{Binding StatusColor}"/>
                                        <TextBlock Text="{Binding LastUpdatedText}" Margin="16,0" FontSize="12"
                                                   Foreground="{StaticResource TextMuted}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="פתח דף תוספים" Command="{Binding OpenExtensionsCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                                    <Button Content="פתח תיקייה" Command="{Binding OpenFolderCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                                    <Button Content="Rollback" Command="{Binding RollbackCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="{StaticResource Warning}" Margin="0,0,8,0"/>
                                    <Button Content="הסר" Command="{Binding RemoveCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Background="{StaticResource Danger}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
