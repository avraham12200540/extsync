<Window x:Class="ExtSync.Agent.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ExtSync Agent" Height="660" Width="920" MinHeight="480" MinWidth="760"
        Icon="/Assets/logo.png"
        FlowDirection="RightToLeft" FontFamily="Segoe UI" WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceMuted}">
    <Window.Resources>
        <!-- Compact per-card action buttons. -->
        <Style x:Key="ItemSecondary" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
        <Style x:Key="ItemWarning" TargetType="Button" BasedOn="{StaticResource WarningButton}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
        <Style x:Key="ItemDanger" TargetType="Button" BasedOn="{StaticResource DangerButton}">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Surface}" Padding="20,14"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Image Source="/Assets/logo.png" Width="38" Height="38" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="19" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}">
                            <Run Text="ExtSync"/><Run Text=" Agent" Foreground="{StaticResource BrandSky}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse Width="9" Height="9" VerticalAlignment="Center"
                                     Fill="{Binding ConnectionColor}"/>
                            <TextBlock Text="{Binding ConnectionStatus}" Margin="7,0,0,0" FontSize="12.5"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding LastCheckText}" Margin="16,0,0,0" FontSize="12.5"
                                       Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding ManagedCountText}" Margin="16,0,0,0" FontSize="12.5"
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="הוספת תוסף מקישור" Command="{Binding AddByLinkCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="בדיקת עדכונים" Command="{Binding CheckUpdatesCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="הגדרות" Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Busy strip: visible while a check/update runs. -->
        <ProgressBar DockPanel.Dock="Top" Height="3" BorderThickness="0" IsIndeterminate="True"
                     Background="{StaticResource SurfaceMuted}" Foreground="{StaticResource BrandTeal}"
                     Visibility="{Binding BusyVisibility}"/>

        <Grid>
            <!-- Empty state: fresh install guidance. -->
            <StackPanel Visibility="{Binding EmptyVisibility}" VerticalAlignment="Center"
                        HorizontalAlignment="Center" MaxWidth="420">
                <Image Source="/Assets/logo.png" Width="72" Height="72" HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="אין עדיין תוספים מנוהלים" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="13"
                           Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"
                           Text="התקינו תוסף מגלריית התוספים באתר, או הדביקו קישור התקנה שקיבלתם ממפתח - ומכאן הוא יתעדכן אצלכם אוטומטית."/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Content="פתיחת גלריית התוספים" Command="{Binding OpenStoreCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <Button Content="הוספה מקישור" Command="{Binding AddByLinkCommand}"
                            Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </StackPanel>

            <!-- Extension list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16"
                          Visibility="{Binding ListVisibility}">
                <ItemsControl ItemsSource="{Binding Extensions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Surface}" CornerRadius="12" Margin="0,0,0,12"
                                    Padding="18,14" BorderBrush="{StaticResource Border}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontSize="15.5" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding DeveloperName}" FontSize="12"
                                                       Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="•" Margin="6,0" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Version}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="•" Margin="6,0" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding Channel}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="•" Margin="6,0" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="{Binding BridgeText}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding StatusColor}"/>
                                            <TextBlock Text="{Binding StatusText}" Margin="7,0,0,0" FontSize="13"
                                                       Foreground="{Binding StatusColor}"/>
                                            <TextBlock Text="{Binding LastUpdatedText}" Margin="16,0,0,0" FontSize="12"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="בדיקה" Command="{Binding CheckCommand}"
                                                Style="{StaticResource ItemSecondary}" Margin="0,0,6,0"/>
                                        <Button Content="{Binding PauseText}" Command="{Binding PauseCommand}"
                                                Style="{StaticResource ItemSecondary}" Margin="0,0,6,0"/>
                                        <Button Content="תיקייה" Command="{Binding OpenFolderCommand}"
                                                Style="{StaticResource ItemSecondary}" Margin="0,0,6,0"/>
                                        <Button Content="דף התוספים" Command="{Binding OpenExtensionsCommand}"
                                                Style="{StaticResource ItemSecondary}" Margin="0,0,6,0"/>
                                        <Button Content="Rollback" Command="{Binding RollbackCommand}"
                                                Style="{StaticResource ItemWarning}" Margin="0,0,6,0"/>
                                        <Button Content="הסרה" Command="{Binding RemoveCommand}"
                                                Style="{StaticResource ItemDanger}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
