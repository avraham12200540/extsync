<Window x:Class="ExtSync.Agent.Views.InstallWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="התקנת תוסף" Height="620" Width="560"
        FlowDirection="RightToLeft" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource SurfaceMuted}">
    <Grid Margin="24">
        <!-- Phase 1: confirm -->
        <StackPanel x:Name="ConfirmPanel">
            <TextBlock Text="התקנת התוסף" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"/>
            <Border Background="{StaticResource Surface}" CornerRadius="12" Padding="18" Margin="0,16"
                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="TxtName" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock x:Name="TxtDeveloper" FontSize="13" Margin="0,4,0,0"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="TxtMeta" FontSize="13" Margin="0,4,0,0"
                               Foreground="{StaticResource TextMuted}"/>
                    <TextBlock x:Name="TxtDescription" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimary}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="הרשאות שהתוסף מבקש:" FontWeight="SemiBold" Margin="0,4"
                       Foreground="{StaticResource TextPrimary}"/>
            <ItemsControl x:Name="PermsList" Margin="0,4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="13" Margin="8,2"
                                   Foreground="{StaticResource TextMuted}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock x:Name="TxtHosts" FontSize="13" Margin="0,4" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}"/>

            <Border Background="#FEF3C7" CornerRadius="8" Padding="12" Margin="0,12">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#92400E"
                    Text="התקנה ראשונה דורשת הפעלת 'מצב מפתח' ב-Chrome וטעינה ידנית של התיקייה. נדריך אותך צעד-אחר-צעד מיד לאחר ההורדה. עדכונים עתידיים יקרו אוטומטית."/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                <Button x:Name="BtnInstall" Content="התקנה באמצעות ExtSync" Click="OnInstall"
                        Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                <Button Content="ביטול" Click="OnCancel" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource TextMuted}"/>
            </StackPanel>
        </StackPanel>

        <!-- Phase 2: guide -->
        <StackPanel x:Name="GuidePanel" Visibility="Collapsed">
            <TextBlock Text="כמעט סיימנו — טעינת התוסף ב-Chrome" FontSize="20" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}"/>
            <Border Background="{StaticResource Surface}" CornerRadius="12" Padding="18" Margin="0,16"
                    BorderBrush="{StaticResource Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="1. בדף chrome://extensions, הפעל 'מצב מפתח' (Developer mode) בפינה." Margin="0,4" TextWrapping="Wrap"/>
                    <TextBlock Text="2. לחץ 'טען פריט לא ארוז' (Load unpacked)." Margin="0,4" TextWrapping="Wrap"/>
                    <TextBlock Text="3. הדבק את הנתיב שהעתקנו (Ctrl+V) ובחר את תיקיית active — בתוכה נמצא manifest.json." Margin="0,4" TextWrapping="Wrap"/>
                    <TextBlock Text="4. לאחר הטעינה לחץ למטה 'טענתי את התוסף ✓'." Margin="0,4" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtFolder" Margin="0,8,0,0" FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
            </Border>

            <Border Background="#EFF6FF" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#1E40AF"
                    Text="אם Chrome פתח בורר פרופילים — בחר פרופיל; ואם נפתח טאב ריק, לחץ 'העתק chrome://extensions' והדבק בשורת הכתובת."/>
            </Border>

            <WrapPanel>
                <Button Content="פתח שוב את דף התוספים" Click="OnOpenExtensions" Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/>
                <Button Content="העתק chrome://extensions" Click="OnCopyUrl" Style="{StaticResource PrimaryButton}" Background="{StaticResource TextMuted}" Margin="0,0,8,8"/>
                <Button Content="העתק נתיב התיקייה" Click="OnCopyPath" Style="{StaticResource PrimaryButton}" Background="{StaticResource TextMuted}" Margin="0,0,8,8"/>
                <Button Content="פתח תיקייה" Click="OnOpenFolder" Style="{StaticResource PrimaryButton}" Background="{StaticResource TextMuted}" Margin="0,0,8,8"/>
            </WrapPanel>

            <TextBlock x:Name="TxtGuideStatus" Margin="0,8" FontSize="13" Foreground="{StaticResource TextMuted}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,8,0,0">
                <Button x:Name="BtnConfirmLoaded" Content="טענתי את התוסף ✓" Click="OnConfirmLoaded"
                        Style="{StaticResource PrimaryButton}" Background="{StaticResource Success}" Margin="0,0,8,0"/>
                <Button x:Name="BtnDone" Content="סיום" Click="OnCancel" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                <Button Content="אני צריך עזרה" Click="OnHelp" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource TextMuted}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
