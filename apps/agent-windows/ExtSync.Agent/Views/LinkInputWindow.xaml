<Window x:Class="ExtSync.Agent.Views.LinkInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Link.WinTitle}" Height="230" Width="480"
        Icon="/Assets/logo.png"
        FlowDirection="{DynamicResource S.Flow}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource SurfaceMuted}">
    <StackPanel Margin="24">
        <TextBlock Text="{DynamicResource S.Link.Prompt}" FontSize="14"
                   Foreground="{StaticResource TextPrimary}"/>
        <TextBox x:Name="InputBox" Margin="0,12" Padding="10" FontSize="13"/>
        <TextBlock Text="{DynamicResource S.Link.Example}"
                   FontSize="11" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,0">
            <Button Content="{DynamicResource S.Link.Ok}" Click="OnOk" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
            <Button Content="{DynamicResource S.Link.Cancel}" Click="OnCancel" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </StackPanel>
</Window>
