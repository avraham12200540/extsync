<Window x:Class="ExtSync.Agent.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="הגדרות ExtSync" Height="560" Width="520"
        FlowDirection="RightToLeft" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource SurfaceMuted}">
    <ScrollViewer>
        <StackPanel Margin="24">
            <TextBlock Text="הגדרות" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"
                       Foreground="{StaticResource TextPrimary}"/>
            <CheckBox x:Name="ChkStartup" Content="הפעלה עם Windows" Margin="0,6"/>
            <CheckBox x:Name="ChkAutoCheck" Content="בדיקת עדכונים אוטומטית" Margin="0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,6">
                <TextBlock Text="תדירות בדיקת עדכונים:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtInterval" Width="60" Margin="8,0" Padding="6"/>
                <ComboBox x:Name="CmbIntervalUnit" Width="100" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="שניות"/>
                    <ComboBoxItem Content="דקות"/>
                    <ComboBoxItem Content="שעות"/>
                    <ComboBoxItem Content="ימים"/>
                </ComboBox>
            </StackPanel>
            <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                       Foreground="{StaticResource TextMuted}"
                       Text="מינימום 30 שניות. ממילא עדכון מתקבל מיידית בעת פרסום (WebSocket), כך שאין צורך באינטרוול קצר."/>
            <CheckBox x:Name="ChkAutoUpdate" Content="התקנת עדכונים אוטומטית" Margin="0,6"/>
            <TextBlock FontSize="11" TextWrapping="Wrap" Margin="22,0,0,6"
                       Foreground="{StaticResource TextMuted}"
                       Text="מוריד ומתקין גרסאות חדשות לבד, ומרענן את התוסף ב-Chrome (מומלץ). אם כבוי — נסמן רק 'עדכון זמין' בלי להתקין."/>
            <CheckBox x:Name="ChkBackground" Content="הורדת עדכונים ברקע" Margin="0,6"/>
            <CheckBox x:Name="ChkNotify" Content="הצגת התראות Windows" Margin="0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,6">
                <TextBlock Text="מספר גרסאות Rollback לשמירה:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtRollback" Width="60" Margin="8,0" Padding="6"/>
            </StackPanel>
            <CheckBox x:Name="ChkBeta" Content="שימוש בגרסת Beta של ה-Agent" Margin="0,6"/>
            <CheckBox x:Name="ChkTelemetry" Content="שיתוף נתוני שימוש אנונימיים (אופציונלי)" Margin="0,6"/>
            <TextBlock Margin="0,12,0,0" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}"
                       Text="ExtSync אוסף מינימום מידע: מזהה מכשיר אקראי, גרסת Agent, מערכת הפעלה כללית, גרסת תוסף וסטטוס עדכון. איננו אוספים היסטוריית גלישה, תוכן דפים או סיסמאות."/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
                <Button Content="שמור" Click="OnSave" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                <Button Content="ייצוא לוגים" Click="OnExportLogs" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                <Button Content="סגור" Click="OnClose" Style="{StaticResource PrimaryButton}"
                        Background="{StaticResource TextMuted}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
