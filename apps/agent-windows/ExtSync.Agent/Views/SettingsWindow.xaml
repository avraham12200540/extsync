<Window x:Class="ExtSync.Agent.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource S.Set.WinTitle}" Height="620" Width="520"
        Icon="/Assets/logo.png"
        FlowDirection="{DynamicResource S.Flow}" FontFamily="Segoe UI"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource SurfaceMuted}">
    <ScrollViewer>
        <StackPanel Margin="24">
            <TextBlock Text="{DynamicResource S.Set.Header}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"
                       Foreground="{StaticResource TextPrimary}"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="{DynamicResource S.Set.Language}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimary}"/>
                <ComboBox x:Name="CmbLanguage" Width="120" Margin="8,0" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="עברית"/>
                    <ComboBoxItem Content="English"/>
                </ComboBox>
            </StackPanel>

            <CheckBox x:Name="ChkStartup" Content="{DynamicResource S.Set.Startup}" Margin="0,6"/>
            <CheckBox x:Name="ChkAutoCheck" Content="{DynamicResource S.Set.AutoCheck}" Margin="0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,6">
                <TextBlock Text="{DynamicResource S.Set.Freq}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBox x:Name="TxtInterval" Width="60" Margin="8,0" Padding="6"/>
                <ComboBox x:Name="CmbIntervalUnit" Width="100" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="{DynamicResource S.Unit.Seconds}"/>
                    <ComboBoxItem Content="{DynamicResource S.Unit.Minutes}"/>
                    <ComboBoxItem Content="{DynamicResource S.Unit.Hours}"/>
                    <ComboBoxItem Content="{DynamicResource S.Unit.Days}"/>
                </ComboBox>
            </StackPanel>
            <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                       Foreground="{StaticResource TextMuted}"
                       Text="{DynamicResource S.Set.MinNote}"/>
            <CheckBox x:Name="ChkAutoUpdate" Content="{DynamicResource S.Set.AutoUpdate}" Margin="0,6"/>
            <TextBlock FontSize="11" TextWrapping="Wrap" Margin="22,0,0,6"
                       Foreground="{StaticResource TextMuted}"
                       Text="{DynamicResource S.Set.AutoUpdateNote}"/>
            <CheckBox x:Name="ChkBackground" Content="{DynamicResource S.Set.Background}" Margin="0,6"/>
            <CheckBox x:Name="ChkNotify" Content="{DynamicResource S.Set.Notify}" Margin="0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,6">
                <TextBlock Text="{DynamicResource S.Set.RollbackKeep}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBox x:Name="TxtRollback" Width="60" Margin="8,0" Padding="6"/>
            </StackPanel>
            <CheckBox x:Name="ChkBeta" Content="{DynamicResource S.Set.Beta}" Margin="0,6"/>
            <CheckBox x:Name="ChkTelemetry" Content="{DynamicResource S.Set.Telemetry}" Margin="0,6"/>
            <TextBlock Margin="0,12,0,0" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource TextMuted}"
                       Text="{DynamicResource S.Set.PrivacyNote}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
                <Button Content="{DynamicResource S.Set.Save}" Click="OnSave" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                <Button Content="{DynamicResource S.Set.Export}" Click="OnExportLogs" Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>
                <Button Content="{DynamicResource S.Set.Close}" Click="OnClose" Style="{StaticResource SecondaryButton}"/>
            </StackPanel>

            <TextBlock x:Name="TxtVersion" Margin="0,14,0,0" FontSize="11"
                       Foreground="{StaticResource TextMuted}"/>
        </StackPanel>
    </ScrollViewer>
</Window>
