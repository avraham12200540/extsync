<Application x:Class="ExtSync.Agent.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Design tokens shared with the web (§39): restrained, professional. -->
            <Color x:Key="BgColor">#0B1220</Color>
            <Color x:Key="SurfaceColor">#111A2E</Color>
            <SolidColorBrush x:Key="Brand" Color="#2563EB" />
            <SolidColorBrush x:Key="Surface" Color="#FFFFFF" />
            <SolidColorBrush x:Key="SurfaceMuted" Color="#F3F4F6" />
            <SolidColorBrush x:Key="TextPrimary" Color="#111827" />
            <SolidColorBrush x:Key="TextMuted" Color="#6B7280" />
            <SolidColorBrush x:Key="Success" Color="#16A34A" />
            <SolidColorBrush x:Key="Warning" Color="#D97706" />
            <SolidColorBrush x:Key="Danger" Color="#DC2626" />
            <SolidColorBrush x:Key="Border" Color="#E5E7EB" />

            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="Background" Value="{StaticResource Brand}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
