{
  "name": "extsync-cli",
  "version": "0.1.0",
  "description": "ExtSync developer CLI — validate, pack, upload and publish Chrome extensions.",
  "type": "module",
  "bin": { "extsync": "./dist/index.js" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/index.ts",
    "test": "node --import tsx --test src/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
