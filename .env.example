# =============================================================================
# ExtSync — example environment file.
# Copy to `.env` and adjust. NEVER commit a real `.env`.
#   cp .env.example .env
# Generate strong secrets with:  openssl rand -hex 32
# =============================================================================

# ---- General ----
ENVIRONMENT=development                 # development | staging | production
LOG_LEVEL=info                          # debug | info | warning | error
PUBLIC_WEB_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# ---- PostgreSQL ----
POSTGRES_USER=extsync
POSTGRES_PASSWORD=extsync_dev_password
POSTGRES_DB=extsync
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async URL used by the API/worker (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://extsync:extsync_dev_password@postgres:5432/extsync
# Sync URL used by Alembic migrations
DATABASE_URL_SYNC=postgresql+psycopg://extsync:extsync_dev_password@postgres:5432/extsync

# ---- Redis (cache, rate-limit, queue broker, pub/sub for WS) ----
REDIS_URL=redis://redis:6379/0

# ---- Object storage (S3 compatible; MinIO in dev) ----
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000   # browser/agent-reachable URL
S3_REGION=us-east-1
S3_ACCESS_KEY=extsync_minio
S3_SECRET_KEY=extsync_minio_password
S3_BUCKET_UPLOADS=extsync-uploads              # raw, unverified developer ZIPs
S3_BUCKET_ARTIFACTS=extsync-artifacts          # validated, immutable artifacts
S3_FORCE_PATH_STYLE=true                        # required for MinIO

# ---- Auth / sessions ----
# 32-byte hex secrets. Rotate by appending old keys as *_OLD (comma separated).
JWT_SECRET=change_me_openssl_rand_hex_32
JWT_ACCESS_TTL_SECONDS=900                       # 15 min access token
JWT_REFRESH_TTL_SECONDS=2592000                  # 30 day refresh token
SESSION_COOKIE_NAME=extsync_session
SESSION_COOKIE_SECURE=false                      # true behind HTTPS in prod
SESSION_COOKIE_SAMESITE=lax
CSRF_SECRET=change_me_openssl_rand_hex_32

# Argon2id parameters (argon2-cffi)
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536
ARGON2_PARALLELISM=4

# ---- Release signing service ----
# The signing service holds the Ed25519 PRIVATE key. It MUST NOT be exposed to
# the public internet or stored in the application DB. The Agent ships only the
# PUBLIC key. See docs/security/signing.md.
SIGNING_SERVICE_URL=http://signing:8090
SIGNING_INTERNAL_TOKEN=change_me_internal_only_token
# Active signing key id (allows rotation: keep old public keys valid for verify)
SIGNING_ACTIVE_KEY_ID=key-2026-01
# Path (inside signing service container) to the Ed25519 private key (PEM)
SIGNING_PRIVATE_KEY_PATH=/run/secrets/ed25519_private.pem
# Public key(s) the platform advertises, keyId=base64. Comma separated.
SIGNING_PUBLIC_KEYS=key-2026-01:BASE64_ED25519_PUBLIC_KEY

# ---- Email (Mailpit in dev) ----
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM="ExtSync <no-reply@extsync.local>"

# ---- Upload / validation limits ----
MAX_UPLOAD_ZIP_BYTES=52428800                    # 50 MB compressed
MAX_EXTRACTED_BYTES=209715200                    # 200 MB extracted (ZIP-bomb guard)
MAX_FILE_COUNT=5000
MAX_DIR_DEPTH=20
VALIDATION_TIMEOUT_SECONDS=120

# ---- Rate limiting ----
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_UPLOAD_PER_HOUR=60

# ---- Google OAuth (optional) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- OpenTelemetry / metrics (optional) ----
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- Frontend (Next.js public vars) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=he
